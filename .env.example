# JWT Configuration
JWT_SECRET=your-very-long-secret-key-change-in-production-min-256-bits-for-hs256-algorithm-security

# Agora Video Configuration (Get from https://console.agora.io)
AGORA_APP_ID=your-agora-app-id-here
AGORA_APP_CERTIFICATE=your-agora-app-certificate-here

# Payment Gateway - Stripe (Get from https://dashboard.stripe.com)
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_SECRET_KEY=sk_secret_your_stripe_secret_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Payment Gateway - Razorpay (Alternative - Get from https://razorpay.com)
RAZORPAY_KEY_ID=razorpay_key_id_here
RAZORPAY_KEY_SECRET=razorpay_key_secret_here

# Email Configuration (Gmail or SendGrid)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_FROM=noreply@telemedicine.com

# SendGrid Alternative
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Business API (Get from https://www.whatsapp.com/business/api)
WHATSAPP_BUSINESS_PHONE_NUMBER=1234567890
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-account-id
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# AWS S3 (For document storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=telemedicine-documents
AWS_S3_REGION=us-east-1

# Application Configuration
APP_NAME=Telemedicine Platform
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
APP_LOGO_URL=https://your-domain.com/logo.png

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.telemedicine.com,https://doctor.telemedicine.com

# Logging
LOG_LEVEL=DEBUG
LOG_PATH=/var/log/telemedicine

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Google Maps API (For doctor location)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase (For push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-firebase-private-key-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_CLIENT_ID=your-firebase-client-id

# Doctor License Verification (External API)
LICENSE_VERIFICATION_API_URL=https://api.license-verification.com
LICENSE_VERIFICATION_API_KEY=your-license-api-key

# Security
BCRYPT_STRENGTH=12
PASSWORD_MIN_LENGTH=8
SESSION_TIMEOUT_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Business Configuration
CONSULTATION_FEE_BASE=5.00
PLATFORM_COMMISSION_PERCENTAGE=20
DOCTOR_PAYOUT_MINIMUM=100.00
SETTLEMENT_CYCLE_DAYS=7

# Compliance
HIPAA_ENCRYPTION_ENABLED=true
GDPR_ENABLED=true
DATA_RETENTION_DAYS=730

# Notification Preferences
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_WHATSAPP_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true

# Feature Flags
FEATURE_VIDEO_CONSULTATION_ENABLED=true
FEATURE_WHATSAPP_INTEGRATION_ENABLED=true
FEATURE_PAYMENT_ENABLED=true
FEATURE_DOCTOR_RATINGS_ENABLED=true
FEATURE_PRESCRIPTION_GENERATION_ENABLED=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000
